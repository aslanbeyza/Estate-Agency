MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/estate-agency?retryWrites=true&w=majority
PORT=3001

# --- Commission policy ---
# Rates are expressed in basis points (1 bps = 0.01%, 10000 = 100%). The
# service validates these at startup and crashes loud if they are invalid;
# leave them unset to use the defaults documented below.
#
# Agency's cut of the total service fee. Default: 5000 (50%).
# COMMISSION_AGENCY_BPS=5000
#
# Listing agent's cut of the *agent pool* (i.e. of whatever is left after
# the agency's share) in the different-agent scenario. The selling agent
# gets the remainder. Default: 5000 (50% of the pool, i.e. 25% of total).
# Ignored in the same-agent scenario where the listing agent receives the
# entire pool.
# COMMISSION_LISTING_AGENT_BPS=5000
